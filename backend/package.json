{
  "name": "timetablex-backend",
  "version": "1.0.0",
  "description": "Backend API for TimeTableX Smart Timetable Optimization System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "optimizer": "cd ../optimizer && source venv/bin/activate && uvicorn main:app --host 127.0.0.1 --port 8000 --reload",
    "dev:all": "concurrently --names \"BACKEND,OPTIMIZER\" --prefix-colors \"cyan,magenta\" \"npm run dev\" \"npm run optimizer\""
  },
  "dependencies": {
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.0"
  },
  "private": true
}
